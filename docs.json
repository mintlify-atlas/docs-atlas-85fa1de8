{
  "$schema": "https://mintlify.com/docs.json",
  "name": "VShop",
  "theme": "almond",
  "colors": {
    "primary": "#d94c4c",
    "light": "#e87070",
    "dark": "#040404"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/VShopApp/mobile"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/VShopApp/mobile"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "getting-started/installation", "getting-started/setup"]
          },
          {
            "group": "Features",
            "pages": [
              "features/shop",
              "features/night-market",
              "features/bundles",
              "features/accessories",
              "features/profile",
              "features/wishlist"
            ]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/environment", "configuration/localization"]
          },
          {
            "group": "Contributing",
            "pages": ["contributing/overview", "contributing/translations"]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "API Utilities",
            "pages": [
              "reference/valorant-api",
              "reference/vshop-api",
              "reference/valorant-assets",
              "reference/wishlist"
            ]
          },
          {
            "group": "State Management",
            "pages": [
              "reference/use-user-store",
              "reference/use-wishlist-store",
              "reference/use-feature-store"
            ]
          }
        ]
      }
    ]
  }
}
