  "keyFeatures": [
    "Daily skin shop viewer with countdown timer",
    "Night Market discounted skin browser",
    "Featured bundle viewer",
    "Accessory shop (buddies, cards, sprays, titles)",
    "Player profile with level, XP, and currency balances",
    "Wishlist with background notifications (donator feature)",
    "Secure on-device authentication via Riot Games SSO",
    "Multi-language support via i18next and Weblate",
    "Stripe-powered donation/supporter system"
  ],
  "publicApiSurface": [
    "getEntitlementsToken(accessToken)",
    "getUserId(accessToken)",
    "getUsername(accessToken, entitlementsToken, userId, region)",
    "getShop(accessToken, entitlementsToken, region, userId)",
    "parseShop(shop)",
    "getBalances(accessToken, entitlementsToken, region, userId)",
    "getProgress(accessToken, entitlementsToken, region, userId)",
    "reAuth(version)",
    "checkDonator(riotId)",
    "getCurrencies()",
    "generatePaymentSheet({ amount, riotId, currencyCode })",
    "checkShop(wishlist)",
    "initBackgroundFetch()",
    "stopBackgroundFetch()",
    "wishlistBgTask()",
    "useUserStore",
    "useWishlistStore",
    "useFeatureStore"
  ]
}
